{
  "expo": {
    "name": "Blood Raven Aftercare",
    "slug": "tattoo-aftercare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tattooaftercare.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take photos of your tattoo healing progress.",
        "NSPhotoLibraryUsageDescription": "Used to save and access tattoo progress photos.",
        "NSPhotoLibraryAddUsageDescription": "Used to save your tattoo progress photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.tattooaftercare.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8A951",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select tattoo progress photos.",
          "cameraPermission": "Used to take tattoo progress photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Used to access your photo library for tattoo progress photos.",
          "savePhotosPermission": "Used to save your tattoo progress photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "b2a80367-e836-4bf3-9399-c9aa055294da"
      }
    },
    "owner": "rushingtechnologies"
  }
}
